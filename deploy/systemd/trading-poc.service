[Unit]
Description=trading-poc FastAPI paper-trade service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/trading-poc
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/trading-poc/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=ubuntu
Group=ubuntu

[Install]
WantedBy=multi-user.target
