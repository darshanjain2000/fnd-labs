# ─── Core mode ─────────────────────────────────────────────
MODE=paper                  # paper | live
BROKER=paper                # paper | kite | angel
PAPER_TRADE=true            # safety belt — true keeps simulation even if broker=kite/angel

# ─── Strategies ────────────────────────────────────────────
ENABLED_STRATEGIES=rsi_reversal,ema_breakout,vwap_pullback
DEFAULT_LOT_SIZE=1

# ─── AI layer (keep OFF for paper-first rollout) ───────────
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_DAILY_USD_CAP=0.30
AGENT_PRESET=balanced       # conservative | balanced | aggressive
AI_FALLBACK_APPROVE_THRESHOLD=0.6

# ─── Memory / context for the LLM ──────────────────────────
MEMORY_SOURCE=db            # db | rag | off
MEMORY_K=5

# ─── RAG ───────────────────────────────────────────────────
RAG_ENABLED=false
CHROMA_PATH=./.chroma

# ─── Broker: Zerodha Kite (paid, ₹2000/mo) ─────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ─── Broker: Angel One SmartAPI (free) ─────────────────────
ANGEL_API_KEY=
ANGEL_API_SECRET=
ANGEL_CLIENT_CODE=
ANGEL_PIN=
ANGEL_TOTP_SECRET=

# ─── Risk caps ─────────────────────────────────────────────
CAPITAL_INR=25000
MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=2.0
MAX_OPEN_POSITIONS=3
MAX_TRADES_PER_DAY=5

# ─── Safety ────────────────────────────────────────────────
KILL_SWITCH=false
BLOCK_EXPIRY_LAST_HOURS=2

# ─── Scheduler / paper-trade runtime ───────────────────────
AUTO_RUN_ENABLED=true
WATCHLIST=NIFTY:NSE,BANKNIFTY:NSE
RUN_INTERVAL_SEC=60
RUN_CANDLE_INTERVAL=1m
FETCH_STAGGER_MS=350
FETCH_MAX_CONCURRENT=3
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
SQUARE_OFF_TIME=15:20

# ─── Logging format / heartbeat ────────────────────────────
LOG_FORMAT=pretty
LOG_HEARTBEAT_INTERVAL_SEC=300

# ─── Storage / logging ─────────────────────────────────────
DATABASE_URL=sqlite:///./trading.db
LOG_LEVEL=INFO

